@startuml UseCases_CinesDelices_v2
'-----------------------------------------------------------------------------
' Diagramme Use Cases unifié — Ciné Délices
' Format VERTICAL : packages empilés du haut vers le bas
' Pour intégration en page portrait
'-----------------------------------------------------------------------------

' En PlantUML, "left to right direction" donne paradoxalement des packages plus
' empilés en hauteur que "top to bottom" (les UC se mettent côte à côte plutôt
' qu'en colonne dans chaque package)
scale 2100*2970
left to right direction

skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam dpi 100

' Charte graphique Ciné Délices
skinparam usecase {
  BackgroundColor #F5F2EC
  BorderColor #8E1F2F
  FontColor #1A1A1A
  ArrowColor #8E1F2F
}
skinparam actor {
  BackgroundColor #1565C0
  BorderColor #1565C0
  FontColor #1A1A1A
}
skinparam package {
  BackgroundColor #FAFAFA
  BorderColor #8E1F2F
  FontColor #8E1F2F
  FontStyle bold
  FontSize 13
}

' === ACTEURS — empilés verticalement à gauche ===
:Visiteur: as V
:Membre: as M
:Admin: as A

' Héritage entre acteurs
M --|> V : hérite de
A --|> M : hérite de

' === PACKAGE 1 : ESPACE PUBLIC ===
package "Espace Public" as P1 {
  usecase "UC01\nPage d'accueil" as UC01
  usecase "UC02\nCatalogue recettes" as UC02
  usecase "UC03\nDétail recette" as UC03
  usecase "UC04\nCatalogue films" as UC04
  usecase "UC05\nCatalogue séries" as UC05
  usecase "UC06\nS'inscrire" as UC06
  usecase "UC07\nSe connecter" as UC07
  usecase "UC08\nReset mot de passe" as UC08
  usecase "UC09\nContact équipe" as UC09

  usecase "Recherche\ntemps réel\n(debounce 400 ms)" as EXT_SEARCH
  usecase "Invitation\ninscription" as EXT_INS
  usecase "Invitation\nconnexion" as EXT_CON
}
UC02 <.. EXT_SEARCH : <<extend>>
UC03 <.. EXT_INS : <<extend>>
UC03 <.. EXT_CON : <<extend>>

' === PACKAGE 2 : ESPACE MEMBRE ===
package "Espace Membre" as P2 {
  usecase "UC10\nMes recettes" as UC10
  usecase "UC11\nCréer recette" as UC11
  usecase "UC12\nModifier recette" as UC12
  usecase "UC13\nSoumettre recette" as UC13
  usecase "UC14\nSupprimer recette" as UC14
  usecase "UC15\nGérer profil" as UC15
  usecase "UC16\nNotifications" as UC16
  usecase "UC17\nSe déconnecter" as UC17
  usecase "UC18\nRecherche TMDB" as UC18

  usecase "Rechercher un\nmédia TMDB\n(autocomplétion)" as UC18
  usecase "Accéder à la liste\nMes Recettes\nd'abord" as INC_LIST
}
UC11 ..> UC18 : <<include>>
UC12 ..> INC_LIST : <<include>>
UC13 ..> INC_LIST : <<include>>
UC14 ..> INC_LIST : <<include>>

' === PACKAGE 3 : ADMINISTRATION ===
package "Administration" as P3 {
  usecase "UC20\nValider recette PENDING" as UC20
  usecase "UC21\nGérer recettes (modération)" as UC21
  usecase "UC22\nValider ingrédients" as UC22
  usecase "Fusionner les\ningrédients doublons" as UC22b
  usecase "UC23\nGérer catégories" as UC23
  usecase "UC24\nGérer utilisateurs" as UC24
  usecase "UC25\nNotifications admin" as UC25
}
UC22 ..> UC22b : <<extend>>
UC20 ..> UC21 : <<include>>

' Liens cachés pour FORCER l'empilement vertical des packages
P1 -[hidden]down- P2
P2 -[hidden]down- P3

' === LIENS ACTEURS → UC ===
V --> UC01
V --> UC02
V --> UC03
V --> UC04
V --> UC05
V --> UC06
V --> UC07
V --> UC08
V --> UC09

M --> UC10
M --> UC11
M --> UC12
M --> UC13
M --> UC14
M --> UC15
M --> UC16
M --> UC17
M --> UC18

A --> UC20
A --> UC21
A --> UC22
A --> UC23
A --> UC24
A --> UC25

@enduml