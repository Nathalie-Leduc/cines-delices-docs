@startuml
' ─────────────────────────────────────────────────────────────
' Use Cases 3/3 — Administrateur · Cinés Délices
' Hérite de Membre (tous ses UCs restent accessibles)
' ─────────────────────────────────────────────────────────────

skinparam backgroundColor #FFFFFF
skinparam defaultFontName Helvetica
skinparam defaultFontSize 13
skinparam actor {
  BorderColor #4A3428
  BackgroundColor #F6F1E8
  FontStyle italic
  FontSize 14
}
skinparam usecase {
  BorderColor #4A3428
  BackgroundColor #000000
  FontColor white
  FontStyle italic
}
skinparam arrowColor #4A3428
skinparam arrowFontSize 11
skinparam rectangle {
  BorderColor #4A3428
  BackgroundColor transparent
  FontSize 13
  FontStyle italic
  FontColor #4A3428
}
skinparam noteBackgroundColor #FFFFFFF
skinparam noteBorderColor #000000
skinparam noteFontSize 11

title Use Cases 3/3 — Administrateur · Cinés Délices

actor "Membre\nconnecté" as M
actor "Administrateur" as A
M <|-- A

rectangle "Cinés Délices — Back-office (JWT + rôle ADMIN)" {
  usecase "Valider les recettes\nPENDING (UC20)" as UC20
  usecase "Gérer toutes\nles recettes (UC21)" as UC21
  usecase "Valider les ingrédients\nen attente (UC22)" as UC22
  usecase "Fusionner les\ningrédients doublons" as UC22b
  usecase "Gérer les\ncatégories (UC23)" as UC23
  usecase "Gérer les\nutilisateurs (UC24)" as UC24
  usecase "Gérer les\nnotifications (UC25)" as UC25
}

A -- UC20
A -- UC21
A -- UC22
A -- UC23
A -- UC24
A -- UC25

UC22 ..> UC22b : <<extend>>
UC20 ..> UC21 : <<include>>

note top of A
  Double middleware :
  · authMiddleware (JWT valide)
  · adminMiddleware (role = ADMIN)
  → 403 Forbidden sinon
end note

' --- PLACEMENT DES NOTES EN DESSOUS DU CADRE ---
note as NoteUC20
  PATCH /api/admin/recipes/:id/publish → PUBLISHED
  PATCH /api/admin/recipes/:id/reject  → DRAFT + motif
end note

note as NoteUC22
  PATCH /api/admin/ingredients/:id/approve
  POST  /api/admin/ingredients/merge (fusion doublons)
  Suppression bloquée (RESTRICT) si ingrédient utilisé
end note

note as NoteUC23
  CRUD complet (catégories)
  DELETE bloqué si recettes liées
  (onDelete: RESTRICT en BDD)
end note

' On lie les notes aux UC avec un lien pointillé
' L'utilisation de "down" force la note à sortir par le bas du rectangle
UC20 ..down.. NoteUC20
UC22 ..down.. NoteUC22
UC23 ..down.. NoteUC23
@enduml