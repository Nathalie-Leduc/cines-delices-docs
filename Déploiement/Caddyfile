:{$PORT} {
    root * /app/dist
    encode gzip

    # Assets avec hash dans le nom (JS, CSS générés par Vite) → cache 1 an
    # Le hash change automatiquement à chaque build → jamais de stale cache
    @hashedAssets {
        path /assets/*
    }
    header @hashedAssets Cache-Control "public, max-age=31536000, immutable"

    # Images et icônes statiques → cache 30 jours
    @staticImages {
        path /img/* /icon/* /favicon.svg
    }
    header @staticImages Cache-Control "public, max-age=2592000"

    # HTML → jamais en cache (toujours la dernière version)
    @html {
        path *.html /
    }
    header @html Cache-Control "no-cache, no-store, must-revalidate"

    # SPA — renvoie index.html pour toutes les routes React Router
    try_files {path} /index.html

    file_server
}
